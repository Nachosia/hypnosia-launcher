# Rust / Tauri environment variables
# Copy this file to .env and fill in real values for local development.
# Never commit .env files to the repository.

# Hypnosia Visuals mod download URL
MOD_JAR_URL=https://github.com/Nachosia/Hypnosia-Visuals/releases/download/v1.0-beta/hypnosia-1.0-beta.jar

# Fabric API dependency URL
FABRIC_API_URL=https://cdn.modrinth.com/data/P7dR8mSH/versions/i5tSkVBH/fabric-api-0.141.3%2B1.21.11.jar

# Fabric Language Kotlin dependency URL
FABRIC_LANGUAGE_KOTLIN_URL=https://cdn.modrinth.com/data/Ha28R6CL/versions/21TRTKmh/fabric-language-kotlin-1.13.10%2Bkotlin.2.3.20.jar
