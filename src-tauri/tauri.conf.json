{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hypnosia Launcher",
  "version": "0.1.3",
  "identifier": "com.nachosia.hypnosia.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hypnosia Launcher",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM0MDM0MDg0MkZGNjJGRDcKUldUWEwvWXZoRUFETkNscExEcFd6NWNlaExLN1lnUG9OcnJCelE2cWFISjY0UlZSTFFiZExZd08K",
      "endpoints": [
        "https://github.com/Nachosia/hypnosia-launcher/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
